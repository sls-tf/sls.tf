{
	"title": "JSON Schema for serverless framework v3.x",
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "object",
	"required": ["service", "provider"],
	"properties": {
		"service": {
			"oneOf": [
				{
					"type": "string",
					"description": "Unique service identifier"
				},
				{
					"type": "object",
					"description": "Service configuration object",
					"required": ["name"],
					"properties": {
						"name": {
							"type": "string",
							"description": "Service name"
						}
					}
				}
			]
		},
		"frameworkVersion": {
			"type": "string",
			"description": "Serverless framework version constraint (e.g., '3', '>=3.0.0 <4.0.0')"
		},
		"custom": {
			"type": "object",
			"description": "Custom service configuration for plugins and user-defined values",
			"additionalProperties": true
		},
		"functions": {
			"type": "object",
			"description": "Function definitions",
			"patternProperties": {
				"^[a-zA-Z0-9_-]+$": {
					"type": "object",
					"description": "Function definition",
					"required": ["handler"],
					"properties": {
						"handler": {
							"type": "string",
							"description": "Function entry point. Syntax varies by runtime"
						},
						"runtime": {
							"type": "string",
							"description": "Function-specific runtime override"
						},
						"memorySize": {
							"type": "number",
							"description": "Memory allocation in MB",
							"minimum": 128,
							"maximum": 10240
						},
						"timeout": {
							"type": "number",
							"description": "Function timeout in seconds",
							"minimum": 1,
							"maximum": 900
						},
						"environment": {
							"type": "object",
							"description": "Function-specific environment variables",
							"additionalProperties": {
								"type": "string"
							}
						},
						"events": {
							"type": "array",
							"description": "List of event triggers",
							"items": {
								"type": "object",
								"description": "Event configuration"
							}
						}
					}
				}
			}
		},
		"resources": {
			"type": "object",
			"description": "CloudFormation resources",
			"properties": {
				"Resources": {
					"type": "object",
					"description": "CloudFormation Resources section"
				},
				"Outputs": {
					"type": "object",
					"description": "CloudFormation Outputs section"
				}
			}
		},
		"package": {
			"type": "object",
			"description": "Function packaging configuration",
			"properties": {
				"individually": {
					"type": "boolean",
					"description": "Package each function individually",
					"default": false
				},
				"patterns": {
					"type": "array",
					"description": "Package patterns (replaces include/exclude in v3+)",
					"items": {
						"type": "string",
						"description": "Pattern (prefix with ! for exclusion)"
					}
				},
				"exclude": {
					"type": "array",
					"description": "Exclude patterns (deprecated, use patterns)",
					"items": {
						"type": "string"
					}
				},
				"include": {
					"type": "array",
					"description": "Include patterns (deprecated, use patterns)",
					"items": {
						"type": "string"
					}
				},
				"artifact": {
					"type": "string",
					"description": "Path to pre-packaged artifact"
				}
			}
		},
		"plugins": {
			"type": "array",
			"description": "Serverless framework plugins",
			"items": {
				"type": "string",
				"description": "Plugin identifier"
			}
		},
		"provider": {
			"type": "object",
			"description": "Cloud provider settings",
			"required": ["name"],
			"properties": {
				"name": {
					"type": "string",
					"description": "Cloud provider name",
					"enum": ["aws", "azure", "google", "cloudflare", "kubernetes"],
					"default": "aws"
				},
				"runtime": {
					"type": "string",
					"description": "Default Lambda runtime",
					"enum": [
						"nodejs18.x", "nodejs16.x", "nodejs14.x",
						"python3.11", "python3.10", "python3.9", "python3.8",
						"ruby3.2", "ruby2.7",
						"java17", "java11", "java8.al2",
						"go1.x",
						"dotnet6", "dotnet7",
						"provided", "provided.al2"
					]
				},
				"stage": {
					"type": "string",
					"description": "Deployment stage",
					"default": "dev"
				},
				"region": {
					"type": "string",
					"description": "AWS region",
					"default": "us-east-1"
				},
				"memorySize": {
					"type": "number",
					"description": "Default memory allocation in MB",
					"minimum": 128,
					"maximum": 10240,
					"default": 1024
				},
				"timeout": {
					"type": "number",
					"description": "Default function timeout in seconds",
					"minimum": 1,
					"maximum": 900,
					"default": 6
				},
				"architecture": {
					"type": "string",
					"description": "Lambda architecture",
					"enum": ["x86_64", "arm64"],
					"default": "x86_64"
				},
				"stackName": {
					"type": "string",
					"description": "Custom CloudFormation stack name"
				},
				"apiName": {
					"type": "string",
					"description": "Custom API Gateway name"
				},
				"profile": {
					"type": "string",
					"description": "AWS CLI profile"
				},
				"logRetentionInDays": {
					"type": "number",
					"description": "CloudWatch Logs retention in days"
				},
				"deploymentPrefix": {
					"type": "string",
					"description": "S3 prefix for deployment artifacts",
					"default": "serverless"
				},
				"versionFunctions": {
					"type": "boolean",
					"description": "Enable function versioning",
					"default": true
				},
				"environment": {
					"type": "object",
					"description": "Service-wide environment variables",
					"additionalProperties": {
						"type": "string"
					}
				},
				"endpointType": {
					"type": "string",
					"description": "API Gateway endpoint type",
					"enum": ["EDGE", "REGIONAL", "PRIVATE"],
					"default": "EDGE"
				},
				"stackTags": {
					"type": "object",
					"description": "CloudFormation stack tags",
					"additionalProperties": {
						"type": "string"
					}
				},
				"tags": {
					"type": "object",
					"description": "Resource tags",
					"additionalProperties": {
						"type": "string"
					}
				},
				"iam": {
					"type": "object",
					"description": "IAM configuration",
					"properties": {
						"role": {
							"oneOf": [
								{
									"type": "string",
									"description": "ARN of existing IAM role"
								},
								{
									"type": "object",
									"description": "IAM role configuration"
								}
							]
						}
					}
				}
			}
		}
	}
}
