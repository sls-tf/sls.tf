{
  "name": "@sls-tf/schema-generator",
  "version": "0.1.0",
  "description": "Automated tooling to generate Terraform validation code from Serverless Framework JSON schemas",
  "main": "src/index.js",
  "bin": {
    "schema-generator": "./bin/schema-generator.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js tests/**/*.js",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "keywords": [
    "terraform",
    "serverless-framework",
    "code-generation",
    "validation",
    "json-schema"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "@json-schema-tools/dereferencer": "^1.6.3",
    "ajv": "^8.12.0",
    "chalk": "^4.1.2",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
