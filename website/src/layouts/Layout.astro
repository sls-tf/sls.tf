---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Serverless Framework to Terraform Conversion Module" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Outfit:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <nav role="navigation" aria-label="Main navigation">
      <div class="nav-container">
        <div class="nav-brand">
          <a href="/">sls.tf</a>
        </div>
        <div class="nav-links">
          <a href="/docs">Docs</a>
          <a href="https://github.com/sls-tf/sls.tf" target="_blank" rel="noopener noreferrer" class="nav-github">GitHub</a>
        </div>
      </div>
    </nav>
    <main id="main-content">
      <slot />
    </main>
    <footer>
      <div class="footer-container">
        <p>sls.tf &mdash; MIT License &mdash; <a href="https://github.com/sls-tf/sls.tf" target="_blank" rel="noopener noreferrer">github.com/sls-tf/sls.tf</a></p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #0C0C0F;
    --bg-2: #141418;
    --bg-3: #1C1C22;
    --fg: #F4F1EB;
    --fg-2: #A8A49C;
    --accent: #F5A623;
    --accent-dim: rgba(245, 166, 35, 0.12);
    --border: #2A2A32;
    --border-bright: #3D3D4A;
    --code-bg: #0A0A0D;
    --code-fg: #E8E4DC;

    --font-display: 'Syne', sans-serif;
    --font-body: 'Outfit', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  html {
    scroll-behavior: smooth;
    background: var(--bg);
    color-scheme: dark;
  }

  body {
    font-family: var(--font-body);
    font-weight: 400;
    line-height: 1.6;
    color: var(--fg);
    background-color: var(--bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--border-bright);
    border-radius: 0;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--accent);
  }

  /* Skip link */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 6px;
    background: var(--accent);
    color: var(--bg);
    padding: 8px 12px;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    z-index: 1000;
    transition: top 0.2s;
  }
  .skip-link:focus {
    top: 6px;
  }

  /* Meta tag for tests */
  meta[name="description"] {
    display: block;
  }

  /* Global code styling */
  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--code-fg);
    background: var(--code-bg);
    padding: 0.15em 0.4em;
    border: 1px solid var(--border);
  }

  pre {
    font-family: var(--font-mono);
    background: var(--code-bg);
    border: 1px solid var(--border);
    padding: 1.5rem;
    overflow-x: auto;
    line-height: 1.7;
    font-size: 0.875rem;
    color: var(--code-fg);
  }

  pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  a {
    color: var(--fg);
    text-decoration: none;
  }
</style>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(12, 12, 15, 0.92);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 52px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-brand a {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--fg);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color 0.15s;
  }

  .nav-brand a:hover {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg-2);
    text-decoration: none;
    transition: color 0.15s;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
  }

  .nav-links a:hover {
    color: var(--fg);
    border-bottom-color: var(--accent);
  }

  main {
    min-height: calc(100vh - 52px - 48px);
  }

  footer {
    border-top: 1px solid var(--border);
    background: var(--bg);
    height: 48px;
    display: flex;
    align-items: center;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
  }

  .footer-container p {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-2);
  }

  .footer-container a {
    color: var(--fg-2);
    transition: color 0.15s;
  }

  .footer-container a:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .nav-container {
      padding: 0 1rem;
    }
    .footer-container {
      padding: 0 1rem;
    }
  }
</style>
