---
import Layout from '../layouts/Layout.astro';
---

<Layout title="sls.tf — serverless.yml to Terraform">

  <!-- ═══════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="hero-inner">

      <div class="hero-left">
        <span class="hero-label">TERRAFORM MODULE</span>
        <h1 class="hero-h1">Serverless &amp; SAM<br/><span class="arrow">&rarr;</span> Terraform</h1>
        <p class="hero-sub">Drop your SAM template.yaml or serverless.yml. Get production Terraform. No rewrites.</p>
        <div class="hero-cta">
          <a href="/docs" class="btn-primary">Get Started &rarr;</a>
          <a href="https://github.com/sls-tf/sls.tf" target="_blank" rel="noopener noreferrer" class="btn-ghost">View on GitHub</a>
        </div>
        <div class="hero-stats">
          <span class="stat">v0.3.16</span>
          <span class="stat-sep">/</span>
          <span class="stat">MIT License</span>
          <span class="stat-sep">/</span>
          <span class="stat">AWS</span>
        </div>
      </div>

      <div class="hero-right">
        <div class="transform-visual">

          <!-- Input window -->
          <div class="code-window" id="window-in">
            <div class="window-bar">
              <span class="dot dot-1"></span>
              <span class="dot dot-2"></span>
              <span class="dot dot-3"></span>
              <span class="window-title">serverless.yml</span>
            </div>
            <pre is:raw class="window-code"><span class="ln">service:</span> my-api

<span class="ln">provider:</span>
  name: aws
  runtime: nodejs20.x
  stage: prod

<span class="ln">functions:</span>
  hello:
    handler: src/hello.handler
    events:
      - httpApi:
          path: /hello
          method: GET</pre>
          </div>

          <!-- Pipeline connector -->
          <div class="pipeline" aria-hidden="true">
            <div class="pipe-line"></div>
            <div class="pipe-dots">
              <span class="pipe-dot"></span>
              <span class="pipe-dot"></span>
              <span class="pipe-dot"></span>
            </div>
            <div class="pipe-label">sls.tf</div>
          </div>

          <!-- Output window -->
          <div class="code-window" id="window-out">
            <div class="window-bar">
              <span class="dot dot-1"></span>
              <span class="dot dot-2"></span>
              <span class="dot dot-3"></span>
              <span class="window-title">main.tf</span>
            </div>
            <pre is:raw class="window-code"><span class="kw">module</span> <span class="str">"api"</span> {
  source = <span class="str">"git::https://github.com/</span>
<span class="str">    sls-tf/sls.tf.git?ref=v0.3.16"</span>

  config_path   = <span class="str">"./serverless.yml"</span>
  aws_region    = <span class="str">"us-east-1"</span>
}

<span class="cm"># Lambda, API GW, IAM roles —</span>
<span class="cm"># all provisioned automatically.</span></pre>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════ CAPABILITIES -->
  <section class="capabilities">
    <div class="section-inner">
      <div class="section-label">CAPABILITIES</div>
      <div class="cap-grid">

        <div class="cap-item">
          <div class="cap-header">
            <span class="cap-arrow">&rarr;</span>
            <strong>AWS SAM Support</strong>
          </div>
          <p>First-class support for AWS SAM template.yaml — Globals, Parameters, and CloudFormation intrinsics included. Serverless Framework serverless.yml works the same way. Point at either; no migration step.</p>
        </div>

        <div class="cap-item">
          <div class="cap-header">
            <span class="cap-arrow">&rarr;</span>
            <strong>Variable Resolution</strong>
          </div>
          <p>Resolves <code>${"{"}self:custom.foo{"}"}</code>, environment-specific overrides, and nested references at plan time.</p>
        </div>

        <div class="cap-item">
          <div class="cap-header">
            <span class="cap-arrow">&rarr;</span>
            <strong>TypeScript Configs</strong>
          </div>
          <p>Evaluates TypeScript serverless.ts exports, including async factory functions that return the config object.</p>
        </div>

        <div class="cap-item">
          <div class="cap-header">
            <span class="cap-arrow">&rarr;</span>
            <strong>API Gateway</strong>
          </div>
          <p>Provisions HTTP API v2 and REST API v1 resources, routes, integrations, and custom authorizers.</p>
        </div>

        <div class="cap-item">
          <div class="cap-header">
            <span class="cap-arrow">&rarr;</span>
            <strong>DynamoDB Tables</strong>
          </div>
          <p>Creates tables declared in resources.Resources with keys, billing mode, TTL, and stream settings preserved.</p>
        </div>

        <div class="cap-item">
          <div class="cap-header">
            <span class="cap-arrow">&rarr;</span>
            <strong>IAM Roles</strong>
          </div>
          <p>Synthesises least-privilege execution roles per function, merging provider-level and function-level statements.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ USAGE -->
  <section class="usage">
    <div class="section-inner">
      <div class="section-label">USAGE</div>
      <h2 class="usage-heading">Reference the module. Point at your config. Done.</h2>

      <div class="usage-window">
        <div class="window-bar">
          <span class="dot dot-1"></span>
          <span class="dot dot-2"></span>
          <span class="dot dot-3"></span>
          <span class="window-title">main.tf</span>
        </div>
        <pre is:raw class="window-code large-code"><span class="kw">module</span> <span class="str">"service"</span> {
  source = <span class="str">"git::https://github.com/sls-tf/sls.tf.git?ref=v0.3.16"</span>

  config_path   = <span class="str">"./template.yaml"</span>  <span class="cm"># serverless.yml, template.yaml, or serverless.ts</span>
  config_format = <span class="str">"sam"</span>             <span class="cm"># yaml | sam | typescript</span>
  aws_region    = <span class="str">"us-east-1"</span>
}</pre>
      </div>

      <div class="usage-callouts">
        <div class="callout">
          <div class="callout-label">One command</div>
          <div class="callout-value"><code>terraform init</code></div>
          <div class="callout-desc">Fetches the module. No npm install. No CLI setup.</div>
        </div>
        <div class="callout-divider"></div>
        <div class="callout">
          <div class="callout-label">Pin a version</div>
          <div class="callout-value"><code>?ref=v0.3.16</code></div>
          <div class="callout-desc">Semver tags on every release. Upgrade on your schedule.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ CTA -->
  <section class="cta">
    <div class="section-inner cta-inner">
      <p class="cta-text">Start converting in 5 minutes</p>
      <a href="/docs" class="btn-primary">Read the docs &rarr;</a>
    </div>
  </section>

</Layout>

<style>
  /* ─── Shared ──────────────────────────────────────────── */
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.14em;
    margin-bottom: 2.5rem;
  }

  /* Code windows */
  .code-window {
    background: var(--code-bg);
    border: 1px solid var(--border-bright);
  }

  .window-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.55rem 0.9rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-3);
  }

  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot-1 { background: var(--accent); opacity: 0.7; }
  .dot-2 { background: var(--border-bright); }
  .dot-3 { background: var(--border-bright); }

  .window-title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-2);
    margin-left: 6px;
    letter-spacing: 0.04em;
  }

  .window-code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.7;
    color: var(--code-fg);
    padding: 1.1rem 1.25rem;
    margin: 0;
    background: transparent;
    border: none;
    overflow-x: auto;
    white-space: pre;
  }

  /* Syntax highlight helpers */
  .kw  { color: #C9A8FF; }
  .str { color: #7EC8A0; }
  .cm  { color: var(--fg-2); font-style: italic; }
  .ln  { color: #5B9BD5; }

  /* Buttons */
  .btn-primary {
    display: inline-block;
    background: var(--accent);
    color: #0C0C0F;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.5rem;
    text-decoration: none;
    border: 1px solid var(--accent);
    transition: background 0.15s, color 0.15s;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    background: #FFB74D;
    border-color: #FFB74D;
  }

  .btn-ghost {
    display: inline-block;
    background: transparent;
    color: var(--fg);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9rem;
    padding: 0.65rem 1.5rem;
    text-decoration: none;
    border: 1px solid var(--border-bright);
    transition: border-color 0.15s, color 0.15s;
  }

  .btn-ghost:hover {
    border-color: var(--fg-2);
    color: var(--fg);
  }

  /* ─── Hero ────────────────────────────────────────────── */
  .hero {
    min-height: calc(100vh - 52px);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    animation: fadeUp 0.7s ease both;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 2rem;
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  .hero-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.16em;
    margin-bottom: 1.5rem;
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.6rem, 5vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin-bottom: 1.5rem;
  }

  .hero-h1 .arrow {
    color: var(--accent);
  }

  .hero-sub {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.15rem;
    color: var(--fg-2);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 440px;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--fg-2);
    letter-spacing: 0.03em;
  }

  .stat-sep {
    color: var(--border-bright);
  }

  /* ─── Transform visual ────────────────────────────────── */
  .hero-right {
    animation: fadeUp 0.7s 0.2s ease both;
  }

  .transform-visual {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #window-in,
  #window-out {
    position: relative;
  }

  /* Pipeline */
  .pipeline {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 1.25rem;
    height: 52px;
    position: relative;
    background: var(--bg-2);
    border-left: 1px solid var(--border-bright);
    border-right: 1px solid var(--border-bright);
  }

  .pipe-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border-bright);
    transform: translateX(-50%);
  }

  .pipe-dots {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-evenly;
    transform: translateX(-50%);
    gap: 4px;
  }

  .pipe-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
    animation: flowDot 1.4s ease-in-out infinite;
  }

  .pipe-dot:nth-child(1) { animation-delay: 0s; }
  .pipe-dot:nth-child(2) { animation-delay: 0.46s; }
  .pipe-dot:nth-child(3) { animation-delay: 0.92s; }

  .pipe-label {
    position: absolute;
    right: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  @keyframes flowDot {
    0%   { opacity: 0; transform: translateY(-12px); }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { opacity: 0; transform: translateY(12px); }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ─── Capabilities ────────────────────────────────────── */
  .capabilities {
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
    padding: 5rem 0;
    animation: fadeUp 0.7s 0.1s ease both;
  }

  .cap-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--border);
  }

  .cap-item {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    padding-right: 2.5rem;
  }

  .cap-item:nth-child(odd) {
    border-right: 1px solid var(--border);
    padding-right: 2.5rem;
    padding-left: 0;
  }

  .cap-item:nth-child(even) {
    padding-left: 2.5rem;
    padding-right: 0;
  }

  .cap-header {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }

  .cap-arrow {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .cap-header strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .cap-item p {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.875rem;
    color: var(--fg-2);
    line-height: 1.65;
    padding-left: 1.45rem;
  }

  /* ─── Usage ───────────────────────────────────────────── */
  .usage {
    padding: 5rem 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    animation: fadeUp 0.7s 0.15s ease both;
  }

  .usage-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--fg);
    letter-spacing: -0.025em;
    margin-bottom: 2.5rem;
    max-width: 600px;
  }

  .usage-window {
    margin-bottom: 2.5rem;
  }

  .large-code {
    font-size: 0.875rem;
    padding: 1.5rem 1.75rem;
  }

  .usage-callouts {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--border-bright);
    background: var(--bg-2);
  }

  .callout {
    padding: 1.5rem 2rem;
    flex: 1;
  }

  .callout-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--fg-2);
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  .callout-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--fg);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .callout-value code {
    background: var(--accent-dim);
    border-color: var(--accent);
    color: var(--accent);
    font-size: 1rem;
    padding: 0.2em 0.5em;
  }

  .callout-desc {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--fg-2);
    font-weight: 300;
  }

  .callout-divider {
    width: 1px;
    background: var(--border-bright);
    flex-shrink: 0;
  }

  /* ─── CTA ─────────────────────────────────────────────── */
  .cta {
    padding: 5rem 0;
    background: var(--accent-dim);
    border-bottom: 1px solid var(--border);
    animation: fadeUp 0.7s 0.2s ease both;
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    text-align: center;
  }

  .cta-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--fg);
    letter-spacing: -0.025em;
  }

  /* ─── Responsive ──────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem;
      gap: 3rem;
    }

    .hero-sub {
      max-width: 100%;
    }

    .transform-visual .window-code {
      font-size: 0.72rem;
    }

    .cap-grid {
      grid-template-columns: 1fr;
    }

    .cap-item:nth-child(odd) {
      border-right: none;
      padding-right: 0;
    }

    .cap-item:nth-child(even) {
      padding-left: 0;
    }
  }

  @media (max-width: 640px) {
    .section-inner {
      padding: 0 1rem;
    }

    .hero-inner {
      padding: 2.5rem 1rem;
    }

    .hero-cta {
      flex-direction: column;
      align-items: flex-start;
    }

    .usage-callouts {
      flex-direction: column;
    }

    .callout-divider {
      width: auto;
      height: 1px;
    }

    .hero-stats {
      flex-wrap: wrap;
    }
  }
</style>
